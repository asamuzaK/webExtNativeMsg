{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationDir": "types",
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "newLine": "LF",
    "removeComments": true,
    "resolveJsonModule": true,
    "target": "esnext",
    "types": ["node"]
  },
  "include": ["index.js"]
}
